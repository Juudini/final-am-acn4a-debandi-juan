<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_lowest"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/topHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_3"
        android:elevation="@dimen/elevation_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" >
        <TextView
            android:id="@+id/topHeader_Label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/headerLabel"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_3xl"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="@dimen/ls_tighter"/>
        <ImageView
            android:id="@+id/topHeader_BtnSearch"
            android:layout_width="@dimen/icon_base"
            android:layout_height="@dimen/icon_base"
            android:src="@drawable/ic_search"
            app:tint="@color/text_secondary" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/size_0"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toTopOf="@id/topHeader"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_lowest"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content" >
               <ImageView
                    android:id="@+id/hero_BgImage"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/hero_height"
                    android:scaleType="centerCrop"
                    android:visibility="invisible"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

               <!-- Hero Skeleton -->
               <View
                    android:id="@+id/heroSkeletonOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/hero_height"
                    android:background="@color/bg_default"
                    android:visibility="visible"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

               <com.google.android.material.card.MaterialCardView
                    android:id="@+id/heroCard"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/size_0"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/bg_shadow"
                    app:cardCornerRadius="@dimen/radius_none"
                    app:layout_constraintTop_toTopOf="@id/hero_BgImage"
                    app:layout_constraintBottom_toBottomOf="@id/hero_BgImage"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:id="@+id/hero_ContentLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_4"
                        android:layout_gravity="bottom">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_2"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/heroSection_PremiereBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="@dimen/ls_wider"
                                android:text="@string/hero_premiere"
                                android:textAllCaps="true"
                                android:textColor="@color/text_title"
                                android:textSize="@dimen/text_xs"
                                android:visibility="invisible" />

                            <Space
                                android:layout_width="@dimen/spacing_4"
                                android:layout_height="wrap_content" />

                            <ImageView
                                android:layout_width="@dimen/icon_base"
                                android:layout_height="@dimen/icon_base"
                                android:src="@drawable/ic_star_rate"
                                app:tint="@color/bg_selected" />

                            <TextView
                                android:id="@+id/heroSection_Rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_1"
                                android:textColor="@color/text_title"
                                android:textSize="@dimen/text_xs"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Skeleton title lines -->
                        <LinearLayout
                            android:id="@+id/heroSkeletonTitleLines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_3"
                            android:orientation="vertical"
                            android:visibility="visible">
                            <View
                                android:layout_width="200dp"
                                android:layout_height="36dp"
                                android:layout_marginBottom="8dp"
                                android:background="@drawable/skeleton_pulse" />
                            <View
                                android:layout_width="140dp"
                                android:layout_height="36dp"
                                android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/heroSection_Label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_3"
                            android:lineSpacingExtra="@dimen/hero_label_line_spacing"
                            android:textColor="@color/text_title"
                            android:textSize="@dimen/text_5xl"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <!-- Skeleton description lines -->
                        <LinearLayout
                            android:id="@+id/heroSkeletonDescLines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_4"
                            android:orientation="vertical"
                            android:visibility="visible">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="14dp"
                                android:layout_marginBottom="6dp"
                                android:background="@drawable/skeleton_pulse" />
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="14dp"
                                android:layout_marginBottom="6dp"
                                android:background="@drawable/skeleton_pulse" />
                            <View
                                android:layout_width="180dp"
                                android:layout_height="14dp"
                                android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/heroSection_Description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_4"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_lg"
                            android:visibility="gone" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/hero_BtnBookmark"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/icon_xl"
                                android:letterSpacing="@dimen/ls_wide"
                                android:text="@string/detail_addToWatchlist"
                                android:textColor="@color/text_selected"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                app:backgroundTint="@color/bg_selected"
                                app:cornerRadius="@dimen/radius_md"
                                app:icon="@drawable/ic_add_to_watchlist"
                                app:iconGravity="textStart"
                                app:iconTint="@color/icon_selected" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_6"
                android:paddingBottom="@dimen/spacing_6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_4">

                    <TextView
                        android:layout_width="@dimen/size_0"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_trending"
                        android:textColor="@color/text_title"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Trending skeleton -->
                <HorizontalScrollView
                    android:id="@+id/trendingSkeletonScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:clipToPadding="false"
                    android:visibility="visible">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="110dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                            <View android:layout_width="110dp" android:layout_height="160dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="90dp" android:layout_height="14dp" android:layout_marginBottom="6dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="60dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="110dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                            <View android:layout_width="110dp" android:layout_height="160dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="90dp" android:layout_height="14dp" android:layout_marginBottom="6dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="60dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="110dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="16dp">
                            <View android:layout_width="110dp" android:layout_height="160dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="90dp" android:layout_height="14dp" android:layout_marginBottom="6dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="60dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="110dp" android:layout_height="wrap_content" android:orientation="vertical">
                            <View android:layout_width="110dp" android:layout_height="160dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="90dp" android:layout_height="14dp" android:layout_marginBottom="6dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="60dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:clipToPadding="false">
                    <LinearLayout
                        android:id="@+id/trendingMoviesContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/spacing_6"
                android:paddingBottom="@dimen/spacing_6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:layout_marginBottom="@dimen/spacing_4">

                    <TextView
                        android:layout_width="@dimen/size_0"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_newReleases"
                        android:textColor="@color/text_title"
                        android:textSize="@dimen/text_xl"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/action_viewAll"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_xs"
                        android:textStyle="bold"
                        android:letterSpacing="@dimen/ls_wider" />
                </LinearLayout>

                <!-- New releases skeleton -->
                <LinearLayout
                    android:id="@+id/newReleasesSkeletonContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:visibility="visible">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                        <View android:layout_width="80dp" android:layout_height="112dp" android:background="@drawable/skeleton_pulse" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:gravity="center_vertical">
                            <View android:layout_width="match_parent" android:layout_height="16dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="120dp" android:layout_height="12dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="match_parent" android:layout_height="12dp" android:layout_marginBottom="4dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="180dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                        <View android:layout_width="80dp" android:layout_height="112dp" android:background="@drawable/skeleton_pulse" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:gravity="center_vertical">
                            <View android:layout_width="match_parent" android:layout_height="16dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="120dp" android:layout_height="12dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="match_parent" android:layout_height="12dp" android:layout_marginBottom="4dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="180dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <View android:layout_width="80dp" android:layout_height="112dp" android:background="@drawable/skeleton_pulse" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:gravity="center_vertical">
                            <View android:layout_width="match_parent" android:layout_height="16dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="120dp" android:layout_height="12dp" android:layout_marginBottom="8dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="match_parent" android:layout_height="12dp" android:layout_marginBottom="4dp" android:background="@drawable/skeleton_pulse" />
                            <View android:layout_width="180dp" android:layout_height="12dp" android:background="@drawable/skeleton_pulse" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/newReleasesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:visibility="gone">
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <include layout="@layout/layout_bottom_navbar" />
</androidx.constraintlayout.widget.ConstraintLayout>