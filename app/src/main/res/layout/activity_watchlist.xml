<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/watchlist_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_surface"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/watchlist_topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="@dimen/size_0"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/watchlist_title"
            android:textColor="@color/text_title"
            android:textSize="@dimen/text_2xl"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/watchlist_BtnSearch"
            android:layout_width="@dimen/icon_base"
            android:layout_height="@dimen/icon_base"
            android:src="@drawable/ic_search"
            app:tint="@color/text_secondary"
            android:contentDescription="@string/bottomNavbar_BtnSearchLabel" />
    </LinearLayout>

    <TextView
        android:id="@+id/watchlist_Message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_10"
        android:gravity="center"
        android:padding="@dimen/spacing_4"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_base"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/watchlist_topBar" />

    <ProgressBar
        android:id="@+id/watchlist_Progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_10"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/watchlist_topBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="@dimen/size_0"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/spacing_4"
        android:paddingTop="@dimen/spacing_4"
        app:layout_constraintBottom_toTopOf="@id/bottomNavbarWrapper"
        app:layout_constraintTop_toBottomOf="@id/watchlist_topBar">

        <LinearLayout
            android:id="@+id/watchlist_Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
    <include layout="@layout/layout_bottom_navbar" />
</androidx.constraintlayout.widget.ConstraintLayout>